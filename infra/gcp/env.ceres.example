# Copy to /etc/ceres/env on a VM (bootstrap creates the directory).
GCP_PROJECT=ceres-project-498208
GCP_REGION=europe-west1
GCP_ZONE=europe-west1-b
BUCKET_NAME=ceres-ai-bucket
CERES_HOME=/opt/ceres
LOCAL_REGISTRY_PATH=/opt/ceres/models/registry
CERES_DL_RUNS=/opt/ceres/dl_runs
# VM spec: e2-highmem-8, 500GB disk (see docs/GCP_VMS.md)
